---
interface Column { key: string; label: string; }
interface Props {
  caption: string;
  columns: Column[];
  rows: Record<string, string | number>[];
}
const { caption, columns, rows } = Astro.props;
---

<div class="blog-table-wrap" tabindex="0" role="region" aria-label={caption}>
  <table class="blog-comparison-table">
    <caption>{caption}</caption>
    <thead><tr>{columns.map((column) => <th scope="col">{column.label}</th>)}</tr></thead>
    <tbody>
      {rows.map((row) => <tr>{columns.map((column, index) => index === 0 ? <th scope="row">{row[column.key]}</th> : <td>{row[column.key]}</td>)}</tr>)}
    </tbody>
  </table>
</div>
