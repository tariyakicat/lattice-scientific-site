---
interface Heading { depth: number; slug: string; text: string; }
interface Props { headings: Heading[]; }
const { headings } = Astro.props;
const items = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

{items.length > 0 && (
  <nav class="blog-toc" aria-label="Table of contents">
    <p>In this article</p>
    <ol>
      {items.map((heading) => <li class:list={{ "is-subheading": heading.depth === 3 }}><a href={`#${heading.slug}`}>{heading.text}</a></li>)}
    </ol>
  </nav>
)}
