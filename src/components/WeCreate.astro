---
import Icon from "./Icon.astro";

const pages = [
  [
    ["Graphical Abstracts", "Capture your research in one clear visual.", "book"],
    ["Figures", "Mechanisms, pathways, and data visualizations.", "branch"],
    ["Journal Covers", "Stand out with bespoke cover art.", "image"],
    ["Slides", "Powerful visuals for presentations and pitch decks.", "presentation"],
    ["Posters", "Scientific posters that inform and impress.", "layout"],
    ["Infographics", "Simplify complex information for any audience.", "pie"],
  ],
  [
    ["Scientific Animation", "Show dynamic processes unfolding over time.", "film"],
    ["Medical Illustration", "Explain anatomy and treatment with precision.", "microscope"],
    ["3D Visualization", "Add depth to molecular and cellular stories.", "box"],
    ["Pathway Diagrams", "Connect mechanisms across biological systems.", "activity"],
    ["Data Visualization", "Turn datasets into readable visual evidence.", "chart"],
    ["Digital Experiences", "Bring research stories to screens and sites.", "monitor"],
  ],
  [
    ["Molecular Illustration", "Reveal structures at the smallest scale.", "dna"],
    ["Research Reports", "Structure long-form scientific narratives.", "file"],
    ["Conference Graphics", "Create a coherent visual system for events.", "presentation"],
    ["Educational Media", "Make specialist knowledge easier to learn.", "book"],
    ["Interactive Figures", "Guide audiences through layered evidence.", "activity"],
    ["Public Communication", "Translate research for wider audiences.", "globe"],
  ],
];
---

<section id="services" class="bg-white py-20 md:py-24">
  <div class="services-journey mx-auto max-w-7xl px-5 md:px-8" data-service-carousel>
    <div class="services-heading" data-reveal><h2>We create</h2><p>Publication-quality visuals for every stage of your research communication.</p></div>
    <div class="service-journey" role="region" aria-label="Scientific illustration services">
      {pages.map((page, pageIndex) => (
        <div class:list={["service-journey-page", { "is-active": pageIndex === 0 }]} data-service-page={pageIndex} aria-hidden={pageIndex === 0 ? "false" : "true"}>
          <div class="service-journey-track">
            <svg class="service-journey-line" viewBox="0 0 1200 160" preserveAspectRatio="none" aria-hidden="true"><path d="M100 52 C166 52 234 100 300 100 S434 52 500 52 S634 100 700 100 S834 52 900 52 S1034 100 1100 100"></path></svg>
            <div class="service-journey-nodes">
              {page.map(([title, description, icon]) => <article class="service-journey-node"><span class="service-node-icon"><Icon name={icon} /></span><h3>{title}</h3><p>{description}</p></article>)}
            </div>
          </div>
        </div>
      ))}
      <div class="service-controls">
        <button class="service-nav-button service-nav-previous" type="button" aria-label="Show previous service page" data-service-prev><Icon name="left" /></button>
        <div class="service-pagination" aria-label="Service pages">{pages.map((_, index) => <button type="button" aria-label={`Go to page ${index + 1}`} aria-current={index === 0 ? "true" : undefined} class:list={{ "is-active": index === 0 }} data-service-dot={index}></button>)}</div>
        <button class="service-nav-button service-nav-next" type="button" aria-label="Show next service page" data-service-next><Icon name="right" /></button>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>("[data-service-carousel]").forEach((carousel) => {
    const pages = [...carousel.querySelectorAll<HTMLElement>("[data-service-page]")];
    const dots = [...carousel.querySelectorAll<HTMLButtonElement>("[data-service-dot]")];
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let index = 0;
    const show = (next: number) => {
      index = (next + pages.length) % pages.length;
      pages.forEach((page, i) => { page.classList.toggle("is-active", i === index); page.setAttribute("aria-hidden", String(i !== index)); page.style.transitionDuration = reduceMotion ? "0ms" : "350ms"; });
      dots.forEach((dot, i) => { dot.classList.toggle("is-active", i === index); i === index ? dot.setAttribute("aria-current", "true") : dot.removeAttribute("aria-current"); });
    };
    carousel.querySelector("[data-service-prev]")?.addEventListener("click", () => show(index - 1));
    carousel.querySelector("[data-service-next]")?.addEventListener("click", () => show(index + 1));
    dots.forEach((dot, i) => dot.addEventListener("click", () => show(i)));
  });
</script>
