---
const currentPath = Astro.url.pathname;
const links = [
  { href: "/", label: "Home" },
  { href: "/portfolio/", label: "Portfolio" },
  { href: "/#services", label: "Services" },
  { href: "/resources/", label: "Resources" },
  { href: "/#process", label: "Process" },
  { href: "/#contact", label: "Contact" },
];
---

<header class="site-header">
  <nav class="site-nav" aria-label="Primary navigation">
    <a href="/" class="site-brand" aria-label="Lattice Visual home">
      <span class="site-brand-mark" aria-hidden="true">LV</span>
      <span>Lattice Visual</span>
    </a>

    <div class="site-nav-links">
      {links.map((link) => (
        <a href={link.href} aria-current={(link.label === "Home" && currentPath === "/") || (link.label === "Resources" && currentPath.startsWith("/resources")) || (link.label === "Portfolio" && currentPath.startsWith("/portfolio")) ? "page" : undefined}>
          {link.label}
        </a>
      ))}
    </div>

    <a href="/#contact" class="site-nav-cta">Start a project <span aria-hidden="true">→</span></a>

    <details class="site-nav-mobile">
      <summary aria-label="Open navigation menu">
        <span></span><span></span><span></span>
      </summary>
      <div>
        {links.map((link) => <a href={link.href}>{link.label}</a>)}
        <a href="/#contact">Start a project</a>
      </div>
    </details>
  </nav>
</header>
