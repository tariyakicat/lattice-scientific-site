---
export interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  type?: "website" | "article";
  prev?: string;
  next?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  image = "/generated/hero-background-wide.webp",
  canonical,
  jsonLd,
  type = "website",
  prev,
  next,
  noindex = false,
} = Astro.props;

const canonicalUrl = canonical
  ? new URL(canonical, Astro.site)
  : new URL(Astro.url.pathname, Astro.site);
const imageUrl = new URL(image, Astro.site);
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="description" content={description} />
<meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large"} />
<link rel="canonical" href={canonicalUrl} />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="alternate" type="application/rss+xml" title="Lattice Visual Blog" href={new URL("/rss.xml", Astro.site)} />
{prev && <link rel="prev" href={new URL(prev, Astro.site)} />}
{next && <link rel="next" href={new URL(next, Astro.site)} />}

<meta property="og:type" content={type} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={imageUrl} />
<meta property="og:site_name" content="Lattice Visual" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />

<title>{title}</title>
{jsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
