---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ResourceCard from "@/components/ResourceCard.astro";
import { getAllResources, resourceSlug } from "@/lib/resources";

const resources = await getAllResources();
const initialQuery = Astro.url.searchParams.get("q") ?? "";
const homeUrl = new URL("/", Astro.site).href;
const resourcesUrl = new URL("/resources/", Astro.site).href;
const itemList = resources.map((resource, index) => ({
  "@type": "ListItem",
  position: index + 1,
  url: new URL(`/resources/${resourceSlug(resource)}/`, Astro.site).href,
  name: resource.data.title,
}));
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Scientific templates & assets",
    description: "Download publication-ready scientific illustration templates, figure kits, slide systems and visual asset packs.",
    url: resourcesUrl,
    mainEntity: { "@type": "ItemList", itemListElement: itemList },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: homeUrl },
      { "@type": "ListItem", position: 2, name: "Resources", item: resourcesUrl },
    ],
  },
];
---

<BaseLayout
  title="Scientific Templates & Assets | Lattice Visual"
  description="Download scientific figure templates, graphical abstract layouts, presentation systems and illustration assets for publication-ready research communication."
  canonical="/resources/"
  jsonLd={jsonLd}
>
  <header class="resource-hub-hero">
    <nav class="breadcrumbs" aria-label="Breadcrumb"><a href="/">Home</a><span aria-hidden="true">/</span><span aria-current="page">Resources</span></nav>
    <p class="section-label">Resources</p>
    <h1>Scientific templates &amp; assets</h1>
    <p>Build clearer graphical abstracts, figures, posters and scientific presentations with publication-ready systems designed for researchers.</p>
  </header>

  <section class="resource-hub" data-resource-hub>
    <div class="resource-hub-tools">
      <form class="resource-hub-search" action="/resources/" method="get" role="search">
        <label for="resource-search">Search the resource library</label>
        <div><input id="resource-search" type="search" name="q" value={initialQuery} placeholder="Search by title, format or use…" autocomplete="off" data-resource-search /><button type="submit">Search</button></div>
      </form>
      <div class="resource-filters" aria-label="Filter resources">
        <button type="button" class="is-active" aria-pressed="true" data-resource-filter="all">All</button>
        <button type="button" aria-pressed="false" data-resource-filter="free">Free</button>
        <button type="button" aria-pressed="false" data-resource-filter="premium">Premium</button>
        <button type="button" aria-pressed="false" data-resource-filter="templates">Templates</button>
        <button type="button" aria-pressed="false" data-resource-filter="asset-library">Asset Library</button>
      </div>
    </div>
    <div class="resource-results-meta" aria-live="polite"><strong data-results-count>{resources.length}</strong> resources</div>
    <div class="resource-grid" data-resource-grid>{resources.map((resource) => <ResourceCard {resource} headingLevel="h2" />)}</div>
    <div class="resource-empty" data-resource-empty hidden><h2>No resources found</h2><p>Try a broader search or reset the active filter.</p><button type="button" data-resource-reset>Show all resources</button></div>
  </section>
</BaseLayout>

<script>
  const hub = document.querySelector<HTMLElement>("[data-resource-hub]");
  if (hub) {
    const search = hub.querySelector<HTMLInputElement>("[data-resource-search]");
    const cards = [...hub.querySelectorAll<HTMLElement>("[data-resource-card]")];
    const buttons = [...hub.querySelectorAll<HTMLButtonElement>("[data-resource-filter]")];
    const count = hub.querySelector<HTMLElement>("[data-results-count]");
    const empty = hub.querySelector<HTMLElement>("[data-resource-empty]");
    let filter = new URL(window.location.href).searchParams.get("filter") ?? "all";
    const validFilters = buttons.map((button) => button.dataset.resourceFilter);
    if (!validFilters.includes(filter)) filter = "all";

    const apply = () => {
      const query = (search?.value ?? "").trim().toLowerCase();
      let visible = 0;
      cards.forEach((card) => {
        const haystack = `${card.dataset.title} ${card.dataset.summary} ${card.dataset.subtype}`;
        const queryMatch = !query || haystack.includes(query);
        const category = card.dataset.category;
        const access = card.dataset.access;
        const filterMatch = filter === "all" || filter === access || (filter === "templates" && category === "Templates") || (filter === "asset-library" && category === "Asset Library");
        const show = queryMatch && filterMatch;
        card.hidden = !show;
        if (show) visible += 1;
      });
      buttons.forEach((button) => { const active = button.dataset.resourceFilter === filter; button.classList.toggle("is-active", active); button.setAttribute("aria-pressed", String(active)); });
      if (count) count.textContent = String(visible);
      if (empty) empty.hidden = visible !== 0;
      const url = new URL(window.location.href);
      query ? url.searchParams.set("q", query) : url.searchParams.delete("q");
      filter !== "all" ? url.searchParams.set("filter", filter) : url.searchParams.delete("filter");
      history.replaceState({}, "", url);
    };
    let searchTimer: number | undefined;
    search?.addEventListener("input", () => { window.clearTimeout(searchTimer); searchTimer = window.setTimeout(apply, 120); });
    hub.querySelector("form")?.addEventListener("submit", (event) => { event.preventDefault(); apply(); });
    buttons.forEach((button) => button.addEventListener("click", () => { filter = button.dataset.resourceFilter ?? "all"; apply(); }));
    hub.querySelector("[data-resource-reset]")?.addEventListener("click", () => { filter = "all"; if (search) search.value = ""; apply(); });
    apply();
  }
</script>
