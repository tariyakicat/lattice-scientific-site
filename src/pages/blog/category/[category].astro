---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/blog/PostCard.astro";
import { blogCategories } from "@/lib/blog-categories";
import { blogUrl, getAllBlogPosts } from "@/lib/blog";

export async function getStaticPaths() {
  return blogCategories.map((category) => ({ params: { category: category.slug }, props: { category } }));
}

interface Props { category: (typeof blogCategories)[number]; }
const { category } = Astro.props;
const posts = (await getAllBlogPosts()).filter((post) => post.data.category === category.name);
const canonical = new URL(`/blog/category/${category.slug}/`, Astro.site).href;
const jsonLd = [
  {
    "@context": "https://schema.org", "@type": "CollectionPage", name: `${category.name} articles`, description: category.intro, url: canonical,
    mainEntity: { "@type": "ItemList", itemListElement: posts.map((post, index) => ({ "@type": "ListItem", position: index + 1, name: post.data.title, url: new URL(blogUrl(post), Astro.site).href })) },
  },
  {
    "@context": "https://schema.org", "@type": "BreadcrumbList", itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: new URL("/", Astro.site).href },
      { "@type": "ListItem", position: 2, name: "Blog", item: new URL("/blog/", Astro.site).href },
      { "@type": "ListItem", position: 3, name: category.name, item: canonical },
    ],
  },
];
---

<BaseLayout title={`${category.name} Guides | Lattice Visual`} description={category.intro} canonical={`/blog/category/${category.slug}/`} image={posts[0]?.data.ogImage?.src ?? posts[0]?.data.heroImage.src} {jsonLd}>
  <header class="blog-taxonomy-hero">
    <nav class="breadcrumbs" aria-label="Breadcrumb"><a href="/">Home</a><span aria-hidden="true">/</span><a href="/blog/">Blog</a><span aria-hidden="true">/</span><span aria-current="page">{category.name}</span></nav>
    <p class="section-label">Article category</p>
    <h1>{category.name}</h1>
    <p>{category.intro}</p>
  </header>
  <section class="blog-taxonomy-list" aria-label={`${category.name} articles`}>
    <div class="blog-card-grid">{posts.map((post) => <PostCard {post} />)}</div>
  </section>
</BaseLayout>
